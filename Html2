<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login Form</title>
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: "Quicksand", sans-serif;
    }
    body {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: #111;
      width: 100%;
      overflow: hidden;
    }
    .ring {
      position: relative;
      width: 300px; /* Adjusted to fit the form size */
      height: auto; /* Changed to auto to wrap the form content */
      display: flex;
      justify-content: center;
      align-items: center;
      flex-direction: column; /* Changed to column for vertical layout */
    }
    /* ... (rest of the provided CSS for rings) ... */
    .login {
      width: 100%;
      max-width: 300px; /* Set a max-width for larger screens */
      margin: auto;
      padding: 20px; /* Added padding for spacing */
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .login h2 {
      font-size: 2em;
      color: #fff;
      text-align: center; /* Center the title text */
    }
    .login input[type="text"],
    .login input[type="password"] {
      width: 100%;
      padding: 12px 20px;
      background: transparent;
      border: 2px solid #fff;
      border-radius: 40px;
      font-size: 1.2em;
      color: #fff;
      margin-bottom: 20px; /* Add space between inputs */
    }
    .login input[type="submit"] {
      padding: 12px 20px;
      background: linear-gradient(45deg, #ff357a, #fff172);
      border: none;
      border-radius: 40px;
      cursor: pointer;
      font-size: 1.2em;
      color: #fff;
    }
    .login input::placeholder {
      color: rgba(255, 255, 255, 0.75);
    }
    /* Adjust the hover effects for the rings if needed */
  </style>
</head>
<body>
  <div class="ring">
    <!-- You can add/remove the i elements based on how many rings you want -->
    <i></i>
    <i></i>
    <i></i>
    <div class="login">
      <h2>Login</h2>
      <form action="/form" method="POST" modeAttribute="user">
        <input type="text" name="username" placeholder="Enter Username" required>
        <input type="password" name="password" placeholder="Enter Password" required>
        <input type="submit" value="Login">
      </form>
    </div>
  </div>
</body>
</html>
