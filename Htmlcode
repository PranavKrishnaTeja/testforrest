import com.fasterxml.jackson.databind.ObjectMapper;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class MapperUtilTest {

    private ObjectMapper objectMapper;
    private MapperUtil mapperUtil;

    @BeforeEach
    void setUp() {
        objectMapper = new ObjectMapper();
        mapperUtil = new MapperUtil(objectMapper);
    }

    @Test
    void readValue_ShouldDeserializeObject() throws Exception {
        TestClass originalObject = new TestClass("Test", 123);
        TestClass deserializedObject = mapperUtil.readValue(originalObject, TestClass.class);

        assertEquals(originalObject.getName(), deserializedObject.getName());
        assertEquals(originalObject.getValue(), deserializedObject.getValue());
    }

    @Test
    void readValue_ShouldThrowRuntimeException_OnDeserializationFailure() {
        String invalidContent = "invalid content";

        assertThrows(RuntimeException.class, () -> mapperUtil.readValue(invalidContent, TestClass.class));
    }

    @Test
    void createAvroInstance_ShouldCreateNewInstance() throws Exception {
        TestAvroClass instance = mapperUtil.createAvroInstance(TestAvroClass.class);

        assertNotNull(instance);
    }

    @Test
    void createAvroInstance_ShouldThrowRuntimeException_OnInstantiationFailure() {
        assertThrows(RuntimeException.class, () -> mapperUtil.createAvroInstance(NonInstantiableClass.class));
    }

    // Test classes
    static class TestClass {
        private String name;
        private int value;

        public TestClass(String name, int value) {
            this.name = name;
            this.value = value;
        }

        public String getName() {
            return name;
        }

        public int getValue() {
            return value;
        }
    }

    static class TestAvroClass {
        // Assuming this is an Avro-generated class
    }

    static class NonInstantiableClass {
        private NonInstantiableClass() {
            // Private constructor prevents instantiation
        }
    }
}