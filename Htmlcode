package com.schwab.brokerage.eventhub.kafka.publisher;

import com.schwab.brokerage.eventhub.kafka.logger.EliLogger;
import com.schwab.brokerage.eventhub.kafka.mapper.EventMapper;
import com.schwab.brokerage.eventhub.kafka.mapper.jsonToAvroMapper.CustomerEventsMapper;
import com.schwab.brokerage.eventhub.kafka.model.EventPayload;
import com.schwab.brokerage.eventhub.kafka.util.MapperUtil;
import com.schwab.kafka.esr.KafkaEndpoint;
import org.apache.kafka.clients.producer.ProducerRecord;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;
import org.springframework.kafka.core.KafkaTemplate;
import org.springframework.kafka.support.SendResult;
import org.springframework.util.concurrent.ListenableFuture;
import org.springframework.util.concurrent.ListenableFutureCallback;
import schwab.discovery.client.ServiceId;

import static org.mockito.ArgumentMatchers.any;
import static org.mockito.Mockito.*;

class CustomerChangeKafkaPublisherTest {

    @Mock
    private EliLogger eliLogger;
    @Mock
    private KafkaTemplate<String, Object> kafkaTemplate;
    @Mock
    private KafkaEndpoint customerChangeKafkaEndpoint;
    @Mock
    private ServiceId customerChangeServiceId;
    @Mock
    private CustomerEventsMapper customerEventsMapper;
    @Mock
    private MapperUtil mapperUtil;
    @Mock
    private ListenableFuture<SendResult<String, Object>> future;

    private CustomerChangeKafkaPublisher customerChangeKafkaPublisher;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        customerChangeKafkaPublisher = new CustomerChangeKafkaPublisher(eliLogger, kafkaTemplate, customerChangeKafkaEndpoint, customerChangeServiceId, customerEventsMapper, mapperUtil);
    }

    @Test
    void publishEvent_ShouldPublishEventSuccessfully() throws Exception {
        EventPayload eventPayload = mock(EventPayload.class);
        EventMapper eventMapper = mock(EventMapper.class);
        Object kafkaAvroPayload = new Object();
        SendResult<String, Object> sendResult = mock(SendResult.class);

        when(customerEventsMapper.convertJsonToAvro(eventPayload, mapperUtil.createAvroInstance(eventMapper.getAvroTarget()))).thenReturn(kafkaAvroPayload);
        when(customerChangeKafkaEndpoint.getTopic()).thenReturn("test-topic");
        when(kafkaTemplate.send(any(ProducerRecord.class))).thenReturn(future);

        customerChangeKafkaPublisher.publishEvent(eventPayload, eventMapper);

        verify(kafkaTemplate).send(any(ProducerRecord.class));
        verify(future).addCallback(any(ListenableFutureCallback.class));
    }

    // Additional test cases for failure scenarios, etc.
}