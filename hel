@Test
    void onFailure_ShouldLogKafkaException() {
        Throwable exception = new RuntimeException("Test exception");
        String expectedTopic = "Test topic";
        String expectedKey = "Test key";

        when(customerChangeKafkaEndpoint.getTopic()).thenReturn(expectedTopic);
        SettableListenableFuture<SendResult<String, Object>> future = new SettableListenableFuture<>();
        future.setException(exception);

        // Trigger the onFailure callback
        future.addCallback(customerChangeKafkaPublisher.getCallback(expectedKey));

        verify(eliLogger).logKafkaException("Publishing failed for Customer event with objectId: " + expectedKey, expectedTopic, new Exception(exception), /* serviceId */);
    }