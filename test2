    @Test
    public void getRabbitListenerEndpoint_ShouldThrowServiceNotFoundException() {
        // Arrange
        ServiceId serviceId = new ServiceId(properties.getListenerServiceKey(), properties.getServiceInterface(), properties.getListenerServicePort());

        when(arcataClient.getEndpoint(serviceId, QoS.MessageConsumer))
                .thenThrow(new ServiceNotFoundException("Service not found"));

        // Act & Assert
        assertThrows(ServiceNotFoundException.class, () -> serviceRegistryLocator.getRabbitListenerEndpoint());
    }

    @Test
    public void getRabbitListenerEndpoint_ShouldThrowServiceRegistryException() {
        // Arrange
        ServiceId serviceId = new ServiceId(properties.getListenerServiceKey(), properties.getServiceInterface(), properties.getListenerServicePort());

        when(arcataClient.getEndpoint(serviceId, QoS.MessageConsumer))
                .thenThrow(new ServiceRegistryException("Registry failure"));

        // Act & Assert
        assertThrows(ServiceRegistryException.class, () -> serviceRegistryLocator.getRabbitListenerEndpoint());
    }

