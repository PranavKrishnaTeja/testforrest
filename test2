Delete deleteQuery = QueryBuilder.deleteFrom(queryInfo.getYbTable());

    boolean hasConditions = false;

    for (QueryColumn column : queryInfo.getPrimaryKeyColumns()) {
        deleteQuery = deleteQuery.whereColumn(column.getName()).isEqualTo(QueryBuilder.bindMarker());
        hasConditions = true;
    }

    if (!hasConditions) {
        return null;
    }

    SimpleStatement statement = deleteQuery.build();
    return cache.getPreparedStatement(session, statement);
