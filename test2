import com.datastax.oss.driver.api.core.CqlSession;
import com.datastax.oss.driver.api.core.cql.PreparedStatement;
import com.datastax.oss.driver.api.querybuilder.QueryBuilder;
import com.datastax.oss.driver.api.querybuilder.update.Assignment;
import com.datastax.oss.driver.api.querybuilder.update.Update;
import com.datastax.oss.driver.api.querybuilder.update.UpdateStart;
import com.datastax.oss.driver.api.querybuilder.update.UpdateWhere;



private PreparedStatement prepareUpdateWithAllColumns(QueryInfo queryInfo, boolean deleteEvent) {
    Update update = QueryBuilder.update(queryInfo.getYbTable());
    Update updateWithAssignments = null;

    for (QueryColumn column : queryInfo.getColumns()) {
        Assignment assignment;
        if (column.getMappingType() == MappingType.JSONB_MAP) {
            assignment = deleteEvent ? QueryBuilder.removeAll(column.getName(), QueryBuilder.bindMarker()) : QueryBuilder.putAll(column.getName(), QueryBuilder.bindMarker());
        } else {
            assignment = QueryBuilder.set(column.getName(), QueryBuilder.bindMarker());
        }
        updateWithAssignments = updateWithAssignments == null ? update.with(assignment) : updateWithAssignments.and(assignment);
    }

    if (updateWithAssignments == null) {
        return null;
    }

    UpdateWhere where = null;
    for (QueryColumn column : queryInfo.getPrimaryKeyColumns()) {
        where = where == null ? updateWithAssignments.whereColumn(column.getName()).isEqualTo(QueryBuilder.bindMarker()) : where.andColumn(column.getName()).isEqualTo(QueryBuilder.bindMarker());
    }

    if (where == null) {
        return null;
    }

    return cache.getPreparedStatement(session, where.asCql());
}
