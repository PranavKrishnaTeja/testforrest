import static org.junit.Assert.assertNotNull;
import static org.mockito.Mockito.*;

import org.junit.Before;
import org.junit.Test;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

public class ArcataServiceRegistryLocatorImplTest {

    @Mock
    private ArcataClient arcataClient;

    @Mock
    private ServiceRegistryConfigProperties properties;

    @InjectMocks
    private ArcataServiceRegistryLocatorImpl serviceRegistryLocator;

    @Before
    public void setUp() {
        MockitoAnnotations.initMocks(this);
        when(properties.getListenerServiceKey()).thenReturn("someServiceKey");
        when(properties.getServiceInterface()).thenReturn("someServiceInterface");
        when(properties.getListenerServicePort()).thenReturn("someServicePort");
    }

    @Test
    public void getRabbitListenerEndpoint_ShouldReturnEndpoint() {
        // Arrange
        Endpoint mockEndpoint = new Endpoint(); // Assuming Endpoint is a class you can instantiate
        ServiceId serviceId = new ServiceId(properties.getListenerServiceKey(), properties.getServiceInterface(), properties.getListenerServicePort());
        
        when(arcataClient.getEndpoint(serviceId, QoS.MessageConsumer)).thenReturn(mockEndpoint);

        // Act
        Endpoint endpoint = serviceRegistryLocator.getRabbitListenerEndpoint();

        // Assert
        assertNotNull(endpoint);
        verify(arcataClient).getEndpoint(serviceId, QoS.MessageConsumer);
    }

    @Test(expected = ArcataRuntimeException.class)
    public void getRabbitListenerEndpoint_ShouldThrowException_WhenEndpointIsNull() {
        // Arrange
        ServiceId serviceId = new ServiceId(properties.getListenerServiceKey(), properties.getServiceInterface(), properties.getListenerServicePort());
        
        when(arcataClient.getEndpoint(serviceId, QoS.MessageConsumer)).thenReturn(null);

        // Act
        serviceRegistryLocator.getRabbitListenerEndpoint(); // This should throw the exception

        // Assert is handled by the expected exception
    }
}