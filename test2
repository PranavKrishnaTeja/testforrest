package com.schwab.brokerage.eventhub.kafka.mapper.jsonToAvroMapper;

import com.schwab.brokerage.event.model.caev9av3.CustomerMerged;
import com.schwab.brokerage.eventhub.kafka.model.EventPayload;
import com.schwab.brokerage.eventhub.kafka.util.MapperUtil;
import com.schwab.avro.brokerage.customer.events.CustomerMerge;
import org.junit.jupiter.api.BeforeEach;
import org.junit.jupiter.api.Test;
import org.mockito.Mock;
import org.mockito.MockitoAnnotations;

import static org.junit.jupiter.api.Assertions.assertEquals;
import static org.mockito.Mockito.when;

class CustomerMergeEventMapperTest {

    @Mock
    private MapperUtil mapperUtil;

    private CustomerMergeEventMapper customerMergeEventMapper;

    @BeforeEach
    void setUp() {
        MockitoAnnotations.openMocks(this);
        customerMergeEventMapper = new CustomerMergeEventMapper(mapperUtil);
    }

    @Test
    void convertJsonToAvro_ShouldConvertEventPayloadToCustomerMerge() {
        EventPayload eventPayload = new EventPayload();
        eventPayload.setPayloadData("{\"afterCustomerIdentifier\":123,\"beforeCustomerIdentifier\":456}");

        CustomerMerged customerMerged = new CustomerMerged();
        customerMerged.setAfterCustomerIdentifier(123L);
        customerMerged.setBeforeCustomerIdentifier(456L);

        when(mapperUtil.readValue(eventPayload.getPayloadData(), CustomerMerged.class)).thenReturn(customerMerged);

        CustomerMerge customerMerge = new CustomerMerge();
        Object result = customerMergeEventMapper.convertJsonToAvro(eventPayload, customerMerge);

        assertEquals(customerMerge, result);
        assertEquals(123, customerMerge.getAfterCustomerId());
        assertEquals(456, customerMerge.getBeforeCustomerId());
    }

    // Additional test cases...
}