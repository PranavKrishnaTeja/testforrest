DeleteSelection deleteSelection = QueryBuilder.deleteFrom(queryInfo.getYbTable());

    boolean hasConditions = false;

    for (QueryColumn column : queryInfo.getPrimaryKeyColumns()) {
        deleteSelection = deleteSelection.whereColumn(column.getName()).isEqualTo(QueryBuilder.bindMarker());
        hasConditions = true;
    }

    if (!hasConditions) {
        return null;
    }

    // Assuming cache.getPreparedStatement() expects a CQL string
    return cache.getPreparedStatement(deleteSelection.asCql());
