import org.junit.Test;
import org.junit.runner.RunWith;
import org.mockito.InjectMocks;
import org.mockito.Mock;
import org.mockito.junit.MockitoJUnitRunner;
import static org.mockito.Mockito.*;
import static org.junit.Assert.*;

@RunWith(MockitoJUnitRunner.class)
public class EnrollmentTransformerTest {

    @Mock
    private ReferenceDataRepository referenceDataRepository;

    @InjectMocks
    private EnrollmentTransformer enrollmentTransformer;

    @Test
    public void testPopulateIdsSetsOfferOrderId() {
        // Given
        Enrollment enrollment = new Enrollment();
        enrollment.setOfferOrderId("12345");
        enrollment.setOfferId("67890");
        // ... set other necessary fields on enrollment as needed

        EnrollmentResource enrollmentResource = new EnrollmentResource();

        String expectedProductResourceKey = "productKey";
        when(referenceDataRepository.getProductResourceKeyFromId(anyInt())).thenReturn(expectedProductResourceKey);

        // When
        enrollmentTransformer.populateIds(enrollment, enrollmentResource);

        // Then
        assertNotNull("Enrollment ID should not be null", enrollmentResource.getEnrollmentId());
        assertEquals("Offer Order ID should match the expected value", Long.valueOf(12345), enrollmentResource.getOfferOrderId());
        // ... assert other fields as necessary
    }
}